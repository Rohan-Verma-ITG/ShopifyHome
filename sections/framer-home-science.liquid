{{ 'framer-home-science.css' | asset_url | stylesheet_tag }}

<section class="fh-science" style="--bg: {{ section.settings.background_color }}; --text: {{ section.settings.text_color }}; --pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <h2 style="text-align: {{ section.settings.heading_alignment }};">{{ section.settings.heading }}</h2>
    <p class="fh-science__intro" style="text-align: {{ section.settings.heading_alignment }};">{{ section.settings.intro }}</p>

    <div class="fh-science__split">
      <div class="fh-science__col">
        {% for block in section.blocks %}
          {% if block.settings.side == 'left' %}
            <article class="fh-science__item" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      <div class="fh-science__center">
        {% if section.settings.center_video != blank %}
          {{ section.settings.center_video | video_tag: controls: true, autoplay: section.settings.autoplay_video, loop: section.settings.loop_video, muted: true, image_size: '1200x' }}
        {% elsif section.settings.center_image != blank %}
          {{ section.settings.center_image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'fh-science__center-image', sizes: '(min-width: 990px) 32vw, 100vw', widths: '400, 700, 900, 1200' }}
        {% endif %}
      </div>

      <div class="fh-science__col">
        {% for block in section.blocks %}
          {% if block.settings.side == 'right' %}
            <article class="fh-science__item" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Framer Home Science",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Science-Driven Formulas You Can Trust" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Freedlight Performance was born out of a need for transparency and efficacy in the equine supplement market." },
    { "type": "image_picker", "id": "center_image", "label": "Center image" },
    { "type": "video", "id": "center_video", "label": "Center video" },
    { "type": "checkbox", "id": "autoplay_video", "label": "Autoplay video", "default": true },
    { "type": "checkbox", "id": "loop_video", "label": "Loop video", "default": true },
    { "type": "select", "id": "heading_alignment", "label": "Heading alignment", "default": "center", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}] },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f4e8d7" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#2d2018" },
    { "type": "range", "id": "padding_top", "min": 24, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 24, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "blocks": [
    { "type": "feature", "name": "Feature", "settings": [
      { "type": "select", "id": "side", "label": "Column", "default": "left", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}] },
      { "type": "text", "id": "title", "label": "Title", "default": "Electrolyte Replenishment" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "Sodium, chloride & potassium restore hydration and fluid balance after exercise or heat exposure." }
    ] }
  ],
  "presets": [{ "name": "Framer Home Science", "blocks": [{"type":"feature","settings":{"side":"left"}},{"type":"feature","settings":{"side":"left"}},{"type":"feature","settings":{"side":"left"}},{"type":"feature","settings":{"side":"right"}},{"type":"feature","settings":{"side":"right"}},{"type":"feature","settings":{"side":"right"}}] }]
}
{% endschema %}
