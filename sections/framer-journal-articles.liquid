{{ 'framer-journal-articles.css' | asset_url | stylesheet_tag }}

<section class="journal-articles">
  <div class="page-width">
    <div class="journal-header">
      <div class="journal-title">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subheading }}</p>
      </div>

      {% if section.settings.show_view_all %}
        <a href="{{ section.settings.blog.url }}" class="journal-view-all">
          {{ section.settings.view_all_text }}
        </a>
      {% endif %}
    </div>

    <div class="journal-grid">
      {% assign blog = blogs[section.settings.blog] %}

      {% for article in blog.articles limit: section.settings.posts_to_show %}
        <div class="journal-card">
          <a href="{{ article.url }}" class="journal-image">
            {% if article.image %}
              <div class="artical-image">
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.title }}"
                  loading="lazy"
                  width="100"
                  height="100"
                >
              </div>
            {% endif %}
          </a>

          <div class="journal-content">
            <p class="journal-date">
              {{ article.published_at | date: '%b %d, %Y' }}
            </p>

            <h3 class="journal-title-card">
              <a href="{{ article.url }}">
                {{ article.title }}
              </a>
            </h3>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Journal Articles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Latest From The Journal"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Expert advice on equine health, nutrition, and performance."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Posts to show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Text",
      "default": "View All"
    }
  ],
  "presets": [
    {
      "name": "Journal Articles"
    }
  ]
}
{% endschema %}
