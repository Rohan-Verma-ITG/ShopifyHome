{{ 'framer-home-newsletter.css' | asset_url | stylesheet_tag }}

<section class="fh-newsletter" style="--bg: {{ section.settings.background_color }}; --text: {{ section.settings.text_color }}; --pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px; --align: {{ section.settings.alignment }};">
  <div class="page-width fh-newsletter__inner">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
    {% form 'customer', class: 'fh-newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" value="{{ form.email }}" aria-label="{{ section.settings.input_label }}" placeholder="{{ section.settings.input_placeholder }}" required>
      <button type="submit" class="fh-button fh-button--dark">{{ section.settings.button_label }}</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Framer Home Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join our community and get 10% off your first order." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Exclusive nutrition tips & guides, early access to products, and members-only discounts." },
    { "type": "text", "id": "input_label", "label": "Input label", "default": "Email address" },
    { "type": "text", "id": "input_placeholder", "label": "Input placeholder", "default": "Enter your email" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "select", "id": "alignment", "label": "Content alignment", "default": "center", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}] },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f4e8d7" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#2d2018" },
    { "type": "range", "id": "padding_top", "min": 24, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 24, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "presets": [{ "name": "Framer Home Newsletter" }]
}
{% endschema %}
