{{ 'framer-social-media.css' | asset_url | stylesheet_tag }}

<section class="fh-instagram">
  <div class="page-width">
    <div class="fh-instagram-header">
      <h2>@FreedlightPerformance</h2>
      <p>Join our community of passionate Horse owners.</p>
    </div>

    <div class="fh-instagram-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="fh-instagram-card" {{ block.shopify_attributes }}>
          <div class="fh-instagram-image">
            <img
              src="{{ block.settings.image | image_url: width: 700 }}"
              alt=""
              loading="lazy"
              width="100"
              height="100"
            >
          </div>

          <div class="fh-instagram-overlay">
            <span class="fh-instagram-icon">
              <!-- Instagram SVG -->
              {% comment %}
                <svg viewBox="0 0 256 256">
                  <path d="M128,82a46,46,0,1,0,46,46A46.06,46.06,0,0,0,128,82Zm0,80a34,34,0,1,1,34-34A34,34,0,0,1,128,162ZM176,26H80A54.06,54.06,0,0,0,26,80v96a54.06,54.06,0,0,0,54,54h96a54.06,54.06,0,0,0,54-54V80A54.06,54.06,0,0,0,176,26Z"/>
                </svg>
              {% endcomment %}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
              >
                <rect x="2" y="2" width="20" height="20" rx="6"
                      stroke="currentColor"
                      stroke-width="2"/>

                <circle cx="12" cy="12" r="5"
                        stroke="currentColor"
                        stroke-width="2"/>

                <circle cx="17.5" cy="6.5" r="1.5"
                        fill="currentColor"/>
              </svg>
            </span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Instagram Grid",
  "settings": [],
  "blocks": [
    {
      "type": "image",
      "name": "Instagram Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Grid",
      "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }]
    }
  ]
}
{% endschema %}
