{{ 'framer-home-real-stories.css' | asset_url | stylesheet_tag }}

<section
  class="fh-real-stories"
  style="--bg: {{ section.settings.section_bg }}; --card-bg: {{ section.settings.card_bg }}; --text: {{ section.settings.text_color }}; --accent: {{ section.settings.accent_color }}; --pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    <div class="fh-real-stories__card">
      {% if section.settings.heading != blank %}
        <h1 class="headding h1">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div
          class="fh-real-stories__slider"
          data-real-stories-slider
          data-autoplay="{{ section.settings.autoplay }}"
          data-speed="{{ section.settings.autoplay_speed }}"
        >
          {% for block in section.blocks %}
            <article
              class="fh-real-stories__slide {% if forloop.first %}is-active{% endif %}"
              data-slide
              {{ block.shopify_attributes }}
            >
              {% if block.settings.rating > 0 %}
                <div class="fh-real-stories__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                  {% for i in (1..5) %}
                    <span class="fh-real-stories__star {% if i <= block.settings.rating %}is-filled{% endif %}">★</span>
                  {% endfor %}
                </div>
              {% endif %}

              {% if block.settings.review_text != blank %}
                <blockquote>{{ block.settings.review_text }}</blockquote>
              {% endif %}

              {% if block.settings.product_image != blank %}
                {{
                  block.settings.product_image
                  | image_url: width: 240
                  | image_tag:
                    loading: 'lazy',
                    class: 'fh-real-stories__product-image',
                    widths: '80, 120, 160, 200, 240',
                    sizes: '120px'
                }}
              {% endif %}

              {% if block.settings.reviewer_name != blank %}
                <p class="fh-real-stories__name">{{ block.settings.reviewer_name }}</p>
              {% endif %}

              {% if block.settings.review_date != blank %}
                <p class="fh-real-stories__date">{{ block.settings.review_date }}</p>
              {% endif %}
            </article>
          {% endfor %}
        </div>

        {% if section.blocks.size > 1 %}
          <div class="fh-real-stories__dots" role="tablist" aria-label="Testimonial navigation">
            {% for block in section.blocks %}
              <button
                type="button"
                class="fh-real-stories__dot {% if forloop.first %}is-active{% endif %}"
                data-dot
                data-index="{{ forloop.index0 }}"
                aria-label="Go to review {{ forloop.index }}"
              ></button>
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
    </div>
  </div>
</section>

<script>
  (() => {
    const sliders = document.querySelectorAll('[data-real-stories-slider]');
    sliders.forEach((slider) => {
      const slides = slider.querySelectorAll('[data-slide]');
      const section = slider.closest('.fh-real-stories');
      const dots = section ? section.querySelectorAll('[data-dot]') : [];
      if (slides.length < 2) return;

      let current = 0;
      const autoplay = slider.dataset.autoplay === 'true';
      const speed = Number(slider.dataset.speed || 5) * 1000;

      const setActive = (index) => {
        slides[current].classList.remove('is-active');
        if (dots[current]) dots[current].classList.remove('is-active');
        current = index;
        slides[current].classList.add('is-active');
        if (dots[current]) dots[current].classList.add('is-active');
      };

      dots.forEach((dot, i) => dot.addEventListener('click', () => setActive(i)));

      if (autoplay) {
        setInterval(() => setActive((current + 1) % slides.length), speed);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Framer Home Real Stories",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real Stories. Real Healing" },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay reviews", "default": true },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 5
    },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ececec" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#eef0f7" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1d2f4f" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#f5b400" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "min": 0, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "I really like this product. It comes in a nice resealable bag with a scooper."
        },
        { "type": "image_picker", "id": "product_image", "label": "Product image" },
        { "type": "text", "id": "reviewer_name", "label": "Reviewer name", "default": "Kimberly P" },
        { "type": "text", "id": "review_date", "label": "Review date", "default": "Oct 30, 2025" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Framer Home Real Stories",
      "blocks": [
        { "type": "review" },
        {
          "type": "review",
          "settings": {
            "reviewer_name": "Laura M",
            "review_date": "Nov 8, 2025",
            "review_text": "Super easy to feed and my horse loves the taste."
          }
        }
      ]
    }
  ]
}
{% endschema %}
