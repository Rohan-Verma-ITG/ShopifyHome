{{ 'framer-home-header.css' | asset_url | stylesheet_tag }}

<header class="fh-header" style="--bg: {{ section.settings.background_color }}; --text: {{ section.settings.text_color }}; --pad-top: {{ section.settings.padding_top }}px; --pad-bottom: {{ section.settings.padding_bottom }}px; --logo-width: {{ section.settings.logo_width }}px;">
  <div class="page-width fh-header__inner">
    <nav class="fh-header__nav fh-header__nav--left" aria-label="Primary left navigation">
      {% if section.settings.left_menu != blank %}
        {% for link in section.settings.left_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% endif %}
    </nav>

    <a class="fh-header__brand" href="{{ section.settings.brand_link }}">
      {% if section.settings.logo_image != blank %}
        {{ section.settings.logo_image | image_url: width: 400 | image_tag: loading: 'eager', class: 'fh-header__logo', widths: '120, 180, 240, 320, 400' }}
      {% else %}
        {{ section.settings.brand_label }}
      {% endif %}
    </a>

    <nav class="fh-header__nav fh-header__nav--right" aria-label="Primary right navigation">
      {% if section.settings.right_menu != blank %}
        {% for link in section.settings.right_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% endif %}
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Framer Home Header",
  "settings": [
    { "type": "link_list", "id": "left_menu", "label": "Left navigation menu" },
    { "type": "link_list", "id": "right_menu", "label": "Right navigation menu" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "range", "id": "logo_width", "min": 80, "max": 320, "step": 10, "unit": "px", "label": "Logo width", "default": 170 },
    { "type": "text", "id": "brand_label", "label": "Fallback brand label", "default": "FREEDLIGHT PERFORMANCE" },
    { "type": "url", "id": "brand_link", "label": "Brand link" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f4e8d7" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#2d2018" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 48, "step": 4, "unit": "px", "label": "Padding top", "default": 16 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 48, "step": 4, "unit": "px", "label": "Padding bottom", "default": 16 }
  ],
  "presets": [{ "name": "Framer Home Header" }]
}
{% endschema %}
