{{ 'freedlight-home.css' | asset_url | stylesheet_tag }}
<script src="{{ 'freedlight-home.js' | asset_url }}" defer="defer"></script>

<div class="fl-home">
  <section class="fl-hero" id="top">
    <img class="fl-hero__bg" src="https://framerusercontent.com/images/AYLv9186ShPV2Ji1u2MDM8vOq4.jpg?scale-down-to=2048&width=5202&height=4000" alt="Horse hero" loading="eager">
    <div class="fl-hero__overlay"></div>
    <header class="fl-nav">
      <a href="#shop">Shop</a>
      <a href="#about">About</a>
      <a class="fl-brand" href="#top">FREEDLIGHT PERFORMANCE</a>
      <a href="#learn">Learn</a>
      <a href="#contact">Contact</a>
    </header>
    <div class="fl-hero__content reveal">
      <h1>Veterinarian Formulated<br>Equine Supplements</h1>
      <a class="fl-btn" href="/collections/all">Shop Now</a>
    </div>
  </section>

  <section class="fl-intro fl-wrap reveal" id="about">
    <div>
      <h2>We're advancing horse health<br>with passion &amp; purpose</h2>
      <img src="https://framerusercontent.com/images/HjEOwiUZCSpSsLpSzD1vZBLRr4.png?scale-down-to=1024&width=2500&height=1509" alt="Horse portrait">
    </div>
    <div>
      <p>Welcome to Freedlight Performance, where a shared love for animals meets the expertise of a dedicated equine veterinarian and the entrepreneurial spirit of a military veteran.</p>
      <a class="fl-btn" href="#learn">Read More</a>
    </div>
  </section>

  <section class="fl-products fl-wrap reveal" id="shop">
    <h2>Featured Products</h2>
    <div class="fl-grid4">
      <article class="fl-card"><img src="https://framerusercontent.com/images/I8MXGkdoLNegJcgPWGAmGBo9V0.png?scale-down-to=512&width=4096&height=4096" alt="Alfalfa Electrolytes"><h3>Alfalfa Electrolytes (2 lbs)</h3><p>$27.00</p></article>
      <article class="fl-card"><img src="https://framerusercontent.com/images/G66pTGl8WZSesMBQvRuygFOW4.png?scale-down-to=512&width=3761&height=3761" alt="Hoof Gain"><h3>Hoof Gain - Blueberry &amp; Kelp</h3><p>$188.00</p></article>
      <article class="fl-card"><img src="https://framerusercontent.com/images/H22BsH1HLlg5VWskzDwxXiD8So.png?scale-down-to=512&width=4096&height=4096" alt="Alfalfa Electrolytes 10lb"><h3>Alfalfa Electrolytes (10 lbs)</h3><p>$132.00</p></article>
      <article class="fl-card"><img src="https://framerusercontent.com/images/P1kdpCB8cjSGXWEqB7xsvGXJgR8.png?scale-down-to=512&width=4096&height=4096" alt="Hoof Gain 30"><h3>Hoof Gain - Blueberry &amp; Kelp (30)</h3><p>$48.00</p></article>
    </div>
  </section>

  <section class="fl-features fl-wrap reveal" id="learn">
    <h2>Science-Driven Formulas You Can Trust</h2>
    <p class="fl-sub">Freedlight Performance was born out of a need for transparency and efficacy in the equine supplement market.</p>
    <div class="fl-grid2">
      <div><h3>Electrolyte Replenishment</h3><p>Sodium, chloride &amp; potassium restore hydration and fluid balance after exercise or heat exposure.</p></div>
      <div><h3>Muscle Performance Support</h3><p>Magnesium &amp; potassium reduce muscle cramps and improve coordination during training and performance.</p></div>
      <div><h3>Bone &amp; Skeletal Strength</h3><p>Calcium citrate provides superior bioavailability for enhanced bone density and skeletal health.</p></div>
      <div><h3>Energy &amp; Metabolic Support</h3><p>Alfalfa delivers natural vitamins &amp; amino acids to improve energy release and overall vitality.</p></div>
      <div><h3>Digestive Support</h3><p>Alfalfa improves gut health and fiber balance for optimal digestive function and nutrient absorption.</p></div>
      <div><h3>Palatability Boost</h3><p>Natural alfalfa sweetness makes the supplement easy-to-eat and highly palatable for all horses.</p></div>
    </div>
  </section>

  <section class="fl-cta reveal">
    <h2>Science &amp; Ingredient Transparency</h2>
    <p>We believe in full transparency. See exactly what goes into our formulas and why.</p>
    <a class="fl-btn" href="/pages/contact">Explore Ingredients</a>
  </section>

  <section class="fl-band fl-wrap reveal">
    <div class="fl-band__dark">
      <h3>Jody Finn, VMD, CMLA, cVMA</h3>
      <p>Equine veterinarian, researcher and founder focused on practical, evidence-based supplementation.</p>
      <a class="fl-btn fl-btn--light" href="#">Learn more about Jody</a>
    </div>
    <div class="fl-band__light">
      <h3>Lance Stutleig</h3>
      <p>Military veteran and operations leader dedicated to quality and consistency in every batch.</p>
      <a class="fl-btn" href="#">More about Lance</a>
    </div>
  </section>

  <section class="fl-newsletter fl-wrap reveal" id="contact">
    <h2>Leave From The Arena</h2>
    <p>Exclusive product updates and educational insights.</p>
    <form class="fl-form" action="#" onsubmit="return false;">
      <input type="email" placeholder="Enter your email" aria-label="Email">
      <button class="fl-btn" type="submit">Join Us</button>
    </form>
  </section>

  <footer class="fl-footer">
    <p>© {{ 'now' | date: '%Y' }} Freedlight Performance</p>
    <a href="#top">Back to top</a>
  </footer>
</div>

{% schema %}
{
  "name": "Freedlight Home",
  "settings": [],
  "presets": [{"name": "Freedlight Home"}]
}
{% endschema %}
