{{ 'framer-home-transparency.css' | asset_url | stylesheet_tag }}

<section
  class="fh-transparency"
  style="--bg: {{ section.settings.background_color }}; --text: {{ section.settings.text_color }}; --pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px; --align: {{ section.settings.alignment }};"
>
  <div class="page-width fh-transparency__inner">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
    {% if section.blocks.size > 0 %}
      <div class="fh-transparency__marquee">
        <marquee behavior="scroll" direction="left" scrollamount="6">
          {% for block in section.blocks %}
            <div class="fh-marquee-card" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                <div class="fh-marquee-img">
                  <img
                    src="{{ block.settings.image | image_url: width: 120 }}"
                    alt="{{ block.settings.text }}"
                    loading="lazy"
                    width="100"
                    height="100"
                  >
                </div>
              {% endif %}

              <div class="fh-marquee-text">
                {{ block.settings.text }}
              </div>
            </div>
          {% endfor %}
        </marquee>
      </div>
    {% endif %}
    {% if section.settings.button_label != blank %}
      <a class="fh-button fh-button--dark" href="{{ section.settings.button_link }}">
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Framer Home Transparency",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Science & Ingredient Transparency" },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "We believe in full transparency. See exactly what goes into our formulas and why."
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore the Science" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    {
      "type": "select",
      "id": "alignment",
      "label": "Content alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },

    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#f8f4ec" }
  ],

  "blocks": [
    {
      "type": "marquee_item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Explore The Sience"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Framer Home Transparency",
      "blocks": [{ "type": "marquee_item" }, { "type": "marquee_item" }, { "type": "marquee_item" }]
    }
  ]
}
{% endschema %}
