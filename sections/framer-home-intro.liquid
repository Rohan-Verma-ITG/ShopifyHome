{{ 'framer-home-intro.css' | asset_url | stylesheet_tag }}

<style>
  .fh-intro__text{
      text-align: {{ section.settings.text_alignment }}  ;

  }
</style>

<section
  class="fh-intro page-width"
  style="
    --bg: {{ section.settings.background_color }};
    --text: {{ section.settings.text_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --img-h: {{ section.settings.primary_image_height }}px;
  "
>
  <h2 class="fh-intro__heading">
    {{ section.settings.heading }}
  </h2>
  <h2 class="fh-intro__heading">
    {{ section.settings.secondary_heading }}
  </h2>
  <div class="fh-intro__grid">
    <!-- LEFT COLUMN -->
    <div class="fh-intro__left">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag: loading: 'lazy', height: section.settings.primary_image_height, class: 'fh-intro__image-main'
        }}
      {% endif %}
    </div>

    <!-- RIGHT COLUMN -->
    <div class="fh-intro__right">
      <div class="fh-intro__text">
      <p class="fh-intro__text">
        {{ section.settings.body }}
      </p>

      {% if section.settings.button_label != blank %}
        <a
          class="fh-button fh-button--dark"
          href="{{ section.settings.button_link }}"
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}

      </div>
      {% if section.settings.second_image != blank %}
        {{
          section.settings.second_image
          | image_url: width: 900
          | image_tag: loading: 'lazy', class: 'fh-intro__image-secondary'
        }}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Framer Home Intro",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "We're advancing horse health"
    },
    {
      "type": "textarea",
      "id": "secondary_heading",
      "label": "Secondary heading",
      "default": "With passion & purpose"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Welcome to Freedlight Performance, where a shared love for animals meets the expertise of a dedicated equine veterinarian and the entrepreneurial spirit of a military veteran."
    },
    { "type": "image_picker", "id": "image", "label": "Primary image" },
    { "type": "image_picker", "id": "second_image", "label": "Second image" },
    {
      "type": "range",
      "id": "primary_image_height",
      "min": 260,
      "max": 760,
      "step": 20,
      "unit": "px",
      "label": "Primary image height",
      "default": 520
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Read More" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    { "type": "checkbox", "id": "mobile_image_second", "label": "Show image below text on mobile", "default": true },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f4e8d7" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#2d2018" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "presets": [{ "name": "Framer Home Intro" }]
}
{% endschema %}
